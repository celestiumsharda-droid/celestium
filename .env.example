# Copy to `.env.local` (gitignored) and fill in your real values.
# Vite exposes only variables prefixed with VITE_ to the browser.

# NASA APOD (and ISS, etc.). DEMO_KEY works for tiny traffic. Get a free
# real key at https://api.nasa.gov/ — rate limit 1000/h instead of 30/h.
VITE_NASA_API_KEY=DEMO_KEY
