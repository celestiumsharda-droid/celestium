{
  "name": "celestium",
  "version": "0.2.0",
  "private": true,
  "description": "A pinnacle of science. The universe, examined.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsx scripts/build-discoveries.ts && tsx scripts/build-catalog.ts && tsx scripts/build-og-images.ts && tsx scripts/build-sitemap.ts && tsx scripts/build-rss.ts",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,js}\"",
    "format": "prettier --write \"src/**/*.{ts,js,css,html,md}\"",
    "test": "playwright test"
  },
  "dependencies": {
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.0",
    "@types/three": "^0.169.0",
    "axe-core": "^4.12.0",
    "eslint": "^9.12.0",
    "lighthouse": "^13.3.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-imagetools": "^7.0.4"
  }
}
